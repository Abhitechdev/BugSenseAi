# ─── BugSense AI Environment Configuration ───

# App
APP_NAME=BugSense AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
TRUSTED_HOSTS=localhost,127.0.0.1,backend,*.railway.app,*.railway.internal
MAX_REQUEST_BODY_BYTES=262144
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
CORS_ORIGIN_REGEX=https://.*\.up\.railway\.app
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1,*.up.railway.app

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
FRONTEND_PORT=3000

# PostgreSQL
POSTGRES_USER=bugsense
POSTGRES_PASSWORD=bugsense_secret
POSTGRES_DB=bugsense_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://bugsense:bugsense_secret@postgres:5432/bugsense_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# AI Provider (nvidia | gemini | openai | openrouter | anthropic)
AI_PROVIDER=nvidia
NVIDIA_API_KEY=your-nvidia-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MODEL=meta/llama-3.3-70b-instruct

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
